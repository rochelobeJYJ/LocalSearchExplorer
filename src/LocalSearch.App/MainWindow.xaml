<Window x:Class="LocalSearch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local File Search Explorer"
        Width="1220"
        Height="760"
        MinWidth="980"
        MinHeight="600"
        Icon="Assets/AppIcon.ico"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F5F8" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D6DCE5" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#5D6673" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />

        <Style TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="29" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#B8C2D0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#B8C2D0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="BorderBrush" Value="#B8C2D0" />
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="ColumnHeaderHeight" Value="32" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E7EBF0" />
            <Setter Property="VerticalGridLinesBrush" Value="#EEF1F5" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#EEF2F7" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#D6DCE5" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                             AutomationProperties.AutomationId="SearchBox"
                             Grid.Column="0"
                             Height="30"
                             FontSize="14"
                             KeyDown="SearchBox_KeyDown" />
                    <ComboBox x:Name="TypeFilterBox"
                              Grid.Column="1"
                              Width="90"
                              Height="30"
                              Margin="8,0,0,0"
                              SelectedIndex="0">
                        <ComboBoxItem Content="전체" />
                        <ComboBoxItem Content="파일만" />
                        <ComboBoxItem Content="폴더만" />
                    </ComboBox>
                    <CheckBox x:Name="IgnoreWhitespaceBox"
                              Grid.Column="2"
                              Margin="10,0,0,0"
                              VerticalAlignment="Center"
                              Content="공백 무시"
                              IsChecked="True" />
                    <CheckBox x:Name="IncludeSubfoldersBox"
                              Grid.Column="3"
                              Margin="10,0,0,0"
                              VerticalAlignment="Center"
                              Content="하위 폴더 포함"
                              IsChecked="True"
                              Checked="ScopeOption_Changed"
                              Unchecked="ScopeOption_Changed" />
                    <CheckBox x:Name="ContentSearchBox"
                              Grid.Column="4"
                              Margin="10,0,0,0"
                              VerticalAlignment="Center"
                              Content="내용 검색"
                              Checked="ContentSearchBox_Checked" />
                    <Button x:Name="SearchButton"
                            AutomationProperties.AutomationId="SearchButton"
                            Grid.Column="5"
                            Content="검색"
                            MinWidth="64"
                            Margin="10,0,0,0"
                            Click="SearchButton_Click" />
                    <Button x:Name="CancelSearchButton"
                            AutomationProperties.AutomationId="CancelSearchButton"
                            Grid.Column="6"
                            Content="중단"
                            MinWidth="64"
                            Margin="6,0,0,0"
                            IsEnabled="False"
                            Click="CancelSearchButton_Click" />
                    <Button x:Name="RefreshButton"
                            Grid.Column="7"
                            Content="스캔"
                            MinWidth="64"
                            Margin="6,0,0,0"
                            Click="RefreshButton_Click" />
                    <Button x:Name="UpdateButton"
                            Grid.Column="8"
                            Content="업데이트"
                            MinWidth="78"
                            Margin="6,0,0,0"
                            Click="UpdateButton_Click" />
                </Grid>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText"
                           AutomationProperties.AutomationId="StatusText" Text="준비됨" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <ProgressBar x:Name="SearchProgressBar"
                             AutomationProperties.AutomationId="SearchProgressBar"
                             Width="120"
                             Height="10"
                             IsIndeterminate="True"
                             Visibility="Collapsed" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusScopeText" Text="기준: 모든 검색 위치" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="DatabaseText" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" MinWidth="240" MaxWidth="560" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="480" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="12" BorderBrush="#E7EBF0" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="검색 위치"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="인덱싱된 폴더 기준으로 검색 범위를 선택합니다."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button x:Name="AddFolderButton"
                                    Grid.Column="1"
                                    Content="폴더 추가"
                                    MinWidth="78"
                                    Click="AddFolderButton_Click" />
                        </Grid>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Padding="12" BorderBrush="#E7EBF0" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBlock Text="인덱스 관리"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="SelectedLocationText"
                                       Margin="0,6,0,0"
                                       Foreground="#334155"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="SelectedRootIndexStatusText"
                                       Margin="0,4,0,8"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                            <WrapPanel>
                                <Button x:Name="IndexContentButton"
                                        Content="내용 인덱싱"
                                        MinWidth="88"
                                        Margin="0,0,6,6"
                                        Click="IndexContentButton_Click" />
                                <Button x:Name="RemoveRootButton"
                                        Content="루트 제거"
                                        MinWidth="78"
                                        Margin="0,0,6,6"
                                        Click="RemoveRootButton_Click" />
                                <Button x:Name="DeleteContentIndexButton"
                                        Content="내용 삭제"
                                        MinWidth="78"
                                        Margin="0,0,6,6"
                                        Click="DeleteContentIndexButton_Click" />
                                <Button x:Name="DeleteAllIndexButton"
                                        Content="전체 삭제"
                                        MinWidth="78"
                                        Margin="0,0,0,6"
                                        Click="DeleteAllIndexButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <TreeView x:Name="LocationTree"
                              BorderThickness="0"
                              Background="{StaticResource SurfaceBrush}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ItemsSource="{Binding LocationNodes}"
                              SelectedItemChanged="LocationTree_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="Padding" Value="2" />
                                <EventSetter Event="Expanded" Handler="LocationTreeItem_Expanded" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Detail}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#E2E8F0"
                          BorderBrush="#CBD5E1"
                          BorderThickness="1,0"
                          Cursor="SizeWE"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ShowsPreview="True" />

            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="0,0,0,1"
                        Padding="12,9">
                    <StackPanel>
                        <TextBlock x:Name="ScopeBreadcrumbText"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="ScopeStatusText"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="SearchHintText"
                                   Margin="0,6,0,0"
                                   Foreground="#7C4A03"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <DataGrid x:Name="ResultsGrid"
                          AutomationProperties.AutomationId="ResultsGrid"
                          ItemsSource="{Binding Results}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          AlternationCount="2"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          EnableColumnVirtualization="True"
                          MouseDoubleClick="ResultsGrid_MouseDoubleClick"
                          Sorting="ResultsGrid_Sorting">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="열기" Click="OpenMenuItem_Click" />
                            <MenuItem Header="상위 폴더 열기" Click="OpenParentMenuItem_Click" />
                            <MenuItem Header="탐색기에서 보기" Click="RevealMenuItem_Click" />
                            <MenuItem Header="속성" Click="PropertiesMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="경로 복사" Click="CopyPathMenuItem_Click" />
                            <MenuItem Header="파일명 복사" Click="CopyNameMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="이름 변경" Click="RenameMenuItem_Click" />
                            <MenuItem Header="삭제" Click="DeleteMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="이 폴더 제외" Click="ExcludeFolderMenuItem_Click" />
                            <MenuItem Header="이 루트 다시 인덱싱" Click="RescanFolderMenuItem_Click" />
                            <MenuItem Header="터미널에서 열기" Click="OpenTerminalMenuItem_Click" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="연번" Binding="{Binding SequenceNumber}" Width="64" SortMemberPath="SequenceNumber" />
                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="260" MinWidth="180" SortMemberPath="Name" />
                        <DataGridTextColumn Header="종류" Binding="{Binding KindDisplay}" Width="90" SortMemberPath="KindDisplay" />
                        <DataGridTextColumn Header="크기" Binding="{Binding SizeDisplay}" Width="105" SortMemberPath="Size" />
                        <DataGridTextColumn Header="수정일" Binding="{Binding ModifiedDisplay}" Width="155" SortMemberPath="ModifiedAt" />
                        <DataGridTextColumn Header="매칭 위치" Binding="{Binding MatchDisplay}" Width="110" SortMemberPath="MatchDisplay" />
                        <DataGridTextColumn Header="전체 경로" Binding="{Binding FullPath}" Width="680" MinWidth="260" CanUserResize="True" SortMemberPath="FullPath" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
